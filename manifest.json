{
  "manifest_version": 3,
  "name": "GitlabClip",
  "version": "1.0.0",
  "description": "Copy GitLab Issue/MR title and URL as Markdown hyperlink",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["scripting"],
  "optional_host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/copy.svg", "icons/check.svg"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.gitlab.com/*/-/issues/*",
        "*://*.gitlab.com/*/-/merge_requests/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
